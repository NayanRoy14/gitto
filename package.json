{
  "name": "@nayanroy/gitto",
  "version": "0.1.0",
  "description": "Plain-language Git & GitHub CLI",
  "type": "module",
  "license": "MIT",
  "author": "NayanRoy14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NayanRoy14/gitto.git"
  },
  "homepage": "https://github.com/NayanRoy14/gitto#readme",
  "bugs": "https://github.com/NayanRoy14/gitto/issues",
  "keywords": [
    "git",
    "github",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "gitto": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@octokit/auth-oauth-device": "^7.1.1",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.18",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.9.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
